# Domain
PUBLIC_BASE_URL=https://merged.legal.org.ua
PORTAL_BASE_URL=https://app.merged.legal.org.ua

# Database
DATABASE_URL=postgres://merged:merged@localhost:5432/merged
REDIS_URL=redis://localhost:6379

# Auth
AUTH_SECRET=change-me-32-byte-random
AUTH_EMAIL_FROM=no-reply@merged.legal.org.ua
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# SMTP (outbound mail via mail.merged.com.ua)
SMTP_HOST=mail.merged.com.ua
SMTP_PORT=465
# SMTP_SECURE defaults to true on 465, false elsewhere; override if needed.
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=merged <no-reply@merged.com.ua>
EMAIL_BRAND_URL=https://merged.com.ua
EMAIL_LOGO_URL=https://portal.merged.com.ua/brand/logo-ink-128.png

# LLM (Claude via Bedrock)
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=eu.anthropic.claude-sonnet-4-6-v1:0

# GitHub App — owns the fork org where candidate assessments live.
# Register the App under the `imerged` org.
# GITHUB_APP_PRIVATE_KEY accepts either raw PEM (with \n escapes) or a
# base64-encoded PEM for easier storage in CI secrets.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=
TASKS_ORG=imerged
ATTEMPTS_ORG=imerged
