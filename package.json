{
  "name": "merged",
  "version": "0.21.3",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:landing": "pnpm --filter @merged/landing dev",
    "dev:portal": "pnpm --filter @merged/portal dev",
