{
  email hello@merged.legal.org.ua
  servers {
    trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22
  }
}

(securityHeaders) {
  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
    Permissions-Policy "geolocation=(), microphone=(), camera=()"
  }
}

# Apex — landing + portal share the hostname. Path-based routing sends
# auth/app/internal-API requests to portal; everything else to landing.
merged.legal.org.ua {
  encode zstd gzip
  import securityHeaders

  @portal path /login /login/* /app /app/* /api/auth /api/auth/* /api/health /api/leads /api/leads/*
  reverse_proxy @portal portal:3000

  reverse_proxy landing:8080

  log {
    output file /var/log/caddy/merged.log
  }
}

# Legacy host — 301 to the apex so any old bookmarks keep working.
portal.legal.org.ua {
  redir https://merged.legal.org.ua{uri} 301
}
